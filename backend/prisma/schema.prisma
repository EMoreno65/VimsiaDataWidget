// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TestEnrollment {
  id                     Int                 @id @default(autoincrement())
  instName               String?
  studentName            String
  grade                  String
  sisEnrollmentStatus    String
  sisStudentType         String
  termName               String
}

model FinanceData {
  id                     Int                 @id @default(autoincrement())
  instName               String?
  studentName            String
  grade                  String
  sisEnrollmentStatus    String
  sisStudentType         String?
  sisStudentStatus       String
  tuition                String
  financialAid           String?
  tuitionRemission       String?
  termName               String
}

model TuitionRate {
  id        Int      @id @default(autoincrement())
  termName  String
  grade     String
  amount    Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt

  @@unique([termName, grade])
}

model AdmissionData {
  id             Int      @id @default(autoincrement())
  termName       String
  applications   Int
  acceptances    Int
  newStudents    Int
}


